# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── AI Providers ────────────────────────────────────────────────────────────
# OpenAI — primary provider for user-facing AI (simulator)
OPENAI_API_KEY="sk-proj-..."
# Model to use for OpenAI calls. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL="gpt-4o-mini"

# Gemini — fallback + internal (quiz, course generation, level test)
GEMINI_API_KEY="AIza..."
# Model to use for Gemini calls. Defaults to gemini-1.5-pro if unset.
GEMINI_MODEL="gemini-1.5-pro"

# ─── AI Provider routing ─────────────────────────────────────────────────────
# Per-feature provider override: "openai" | "gemini"
# All user-facing features default to "openai" if unset.
SIMULATOR_AI_PROVIDER="openai"
SPEECH_AI_PROVIDER="openai"
WRITING_AI_PROVIDER="openai"
LEVEL_TEST_AI_PROVIDER="openai"

# Force ALL features to one provider (overrides all per-feature settings above).
# Leave unset for default routing.
# AI_PROVIDER_OVERRIDE="openai"

# ─── Feature flags ───────────────────────────────────────────────────────────
# Set to "false" to disable the AI course generation endpoint (admin-only).
# When disabled, the endpoint returns 503. Defaults to "true" if unset.
ENABLE_COURSE_GENERATION="false"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── Azure TTS ───────────────────────────────────────────────────────────────
AZURE_TTS_KEY="your-azure-key"
AZURE_TTS_REGION="westeurope"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  CENTER_MANAGER
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  FAILED
}

enum PaymentMethod {
  MTN_MOBILE_MONEY
  ORANGE_MONEY
  EXPRESS_UNION
  CARD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ANNUAL
}

enum ModuleType {
  LESSON
  QUIZ
  CONVERSATION
  VIDEO
}

enum DifficultyLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                String    @id @default(uuid())
  supabaseId        String    @unique
  email             String    @unique
  fullName          String
  phone             String?
  avatarUrl         String?
  role              Role      @default(STUDENT)
  preferredLang     String    @default("fr")
  country           String    @default("CM")
  city              String?
  xpTotal           Int       @default(0)
  streakDays        Int       @default(0)
  lastActiveAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  onboardingDone    Boolean   @default(false)
  germanLevel       String?
  learningGoal      String?
  availability      String?
  preferredSchedule String?
  dateOfBirth       DateTime?
  gender            String?
  classCode         String?
  studentType       String?   @default("solo")
  classroomCode     String?
  isValidated       Boolean   @default(false)
  validatedAt       DateTime?
  validatedBy       String?
  testAttempts      Int       @default(0)
  testScore         Float?
  levelAssignedAt   DateTime?
  centerId          String?

  enrollments           Enrollment[]
  moduleProgress        ModuleProgress[]
  conversationSessions  ConversationSession[]
  subscriptions         Subscription[]
  payments              Payment[]
  quizAttempts          QuizAttempt[]
  badges                UserBadge[]
  notifications         Notification[]
  teacher               Teacher?
  classroomEnrollments  ClassroomEnrollment[]
  assignmentSubmissions AssignmentSubmission[]
  createdGroups         StudentGroup[]
  groupMemberships      StudentGroupMember[]
  levelHistory          LevelHistory[]
  classJoinRequests     ClassJoinRequest[]
  sentInvites           StudyGroupInvite[]   @relation("inviteSent")
  receivedInvites       StudyGroupInvite[]   @relation("inviteReceived")
  connections           UserConnection[]     @relation("connections")
  connectedBy           UserConnection[]     @relation("connectedBy")

  @@index([email])
  @@index([supabaseId])
  @@map("users")
}

model Course {
  id            String          @id @default(uuid())
  title         String
  description   String
  coverImageUrl String?
  level         DifficultyLevel
  isPublished   Boolean         @default(false)
  isFree        Boolean         @default(false)
  durationHours Float?
  tags          String[]
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  modules     Module[]
  enrollments Enrollment[]

  @@index([level])
  @@index([isPublished])
  @@map("courses")
}

model Module {
  id          String     @id @default(uuid())
  courseId    String
  title       String
  description String?
  type        ModuleType
  content     Json?
  videoUrl    String?
  sortOrder   Int        @default(0)
  xpReward    Int        @default(0)
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course               Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleProgress       ModuleProgress[]
  conversationSessions ConversationSession[]
  quizQuestions        QuizQuestion[]
  quizAttempts         QuizAttempt[]
  assignments          Assignment[]

  @@index([courseId])
  @@map("modules")
}

model Enrollment {
  id          String         @id @default(uuid())
  userId      String
  courseId    String
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?
  enrolledAt  DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model ModuleProgress {
  id          String         @id @default(uuid())
  userId      String
  moduleId    String
  status      ProgressStatus @default(NOT_STARTED)
  score       Float?
  timeSpent   Int?
  completedAt DateTime?
  startedAt   DateTime?
  updatedAt   DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@map("module_progress")
}

model ConversationSession {
  id             String          @id @default(uuid())
  userId         String
  moduleId       String?
  scenario       String
  level          DifficultyLevel
  history        Json            @default("[]")
  scoreGlobal    Float?
  scoreGrammaire Float?
  scoreVocab     Float?
  scoreFluence   Float?
  errorCount     Int             @default(0)
  wordCount      Int             @default(0)
  duration       Int?
  feedback       String?
  isCompleted    Boolean         @default(false)
  startedAt      DateTime        @default(now())
  completedAt    DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([moduleId])
  @@index([scenario])
  @@map("conversation_sessions")
}

model QuizQuestion {
  id            String  @id @default(uuid())
  moduleId      String
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  sortOrder     Int     @default(0)

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizAnswers QuizAnswer[]

  @@index([moduleId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id        String   @id @default(uuid())
  userId    String
  moduleId  String
  score     Float
  isPassed  Boolean
  timeSpent Int?
  attemptNo Int      @default(1)
  createdAt DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([userId])
  @@index([moduleId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id             String @id @default(uuid())
  attemptId      String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model Subscription {
  id           String             @id @default(uuid())
  userId       String
  plan         SubscriptionPlan
  status       SubscriptionStatus @default(PENDING)
  priceXAF     Int
  startDate    DateTime?
  endDate      DateTime?
  autoRenew    Boolean            @default(false)
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  subscriptionId String?
  amountXAF      Int
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  phoneNumber    String?
  operatorTxId   String?
  operatorRef    String?
  metadata       Json?
  failureReason  String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([operatorTxId])
  @@map("payments")
}

model Badge {
  id          String @id @default(uuid())
  name        String @unique
  description String
  iconUrl     String?
  condition   Json

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Teacher models ───────────────────────────────────────────────────────────

model Teacher {
  id                   String   @id @default(uuid())
  userId               String   @unique
  bio                  String?
  speciality           String[]
  languages            String[]
  isVerified           Boolean  @default(false)
  centerId             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  diploma              String?
  yearsExp             Int?
  certifications       String[]
  maxStudents          Int      @default(20)
  hourlyRate           Int?
  availabilitySchedule Json?
  code                 String?  @unique

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  center     LanguageCenter? @relation(fields: [centerId], references: [id])
  classrooms Classroom[]

  @@map("teachers")
}

model Classroom {
  id          String          @id @default(uuid())
  name        String
  description String?
  teacherId   String
  level       DifficultyLevel
  maxStudents Int             @default(30)
  isActive    Boolean         @default(true)
  code        String          @unique
  centerId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  teacher     Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  center      LanguageCenter?      @relation(fields: [centerId], references: [id])
  enrollments ClassroomEnrollment[]
  assignments Assignment[]

  @@map("classrooms")
}

model ClassroomEnrollment {
  id          String   @id @default(uuid())
  classroomId String
  userId      String
  joinedAt    DateTime @default(now())
  isActive    Boolean  @default(true)

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@map("classroom_enrollments")
}

model Assignment {
  id          String    @id @default(uuid())
  classroomId String
  title       String
  description String?
  moduleId    String?
  dueDate     DateTime?
  maxScore    Int       @default(100)
  createdAt   DateTime  @default(now())

  classroom   Classroom              @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  module      Module?                @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  assignmentId String
  userId       String
  score        Float?
  feedback     String?
  submittedAt  DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@map("assignment_submissions")
}

model StudentGroup {
  id         String           @id @default(uuid())
  name       String
  creatorId  String
  code       String           @unique
  maxMembers Int              @default(10)
  level      DifficultyLevel?
  isActive   Boolean          @default(true)
  isPaid     Boolean          @default(false)
  priceXAF   Int              @default(1500)
  createdAt  DateTime         @default(now())

  creator User                 @relation(fields: [creatorId], references: [id])
  members StudentGroupMember[]

  @@map("student_groups")
}

model StudentGroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)

  group StudentGroup @relation(fields: [groupId], references: [id])
  user  User         @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("student_group_members")
}

model LevelHistory {
  id        String   @id @default(uuid())
  userId    String
  oldLevel  String
  newLevel  String
  reason    String
  changedBy String
  changedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("level_history")
}

model LanguageCenter {
  id           String    @id @default(uuid())
  name         String
  description  String?
  city         String
  country      String    @default("CM")
  phone        String?
  email        String?
  logoUrl      String?
  isVerified   Boolean   @default(false)
  plan         String    @default("starter")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  region       String?
  address      String?
  website      String?
  socialMedia  Json?
  openingHours Json?
  maxAdmins    Int       @default(5)
  rccm         String?
  centerType   String?
  foundedAt    DateTime?
  code         String?   @unique

  teachers   Teacher[]
  classrooms Classroom[]

  @@map("language_centers")
}

model ClassJoinRequest {
  id            String    @id @default(uuid())
  fromUserId    String
  toClassroomId String?
  toGroupId     String?
  status        String    @default("pending")
  message       String?
  createdAt     DateTime  @default(now())
  respondedAt   DateTime?
  respondedBy   String?
  fromUser      User      @relation(fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toClassroomId])
  @@map("class_join_requests")
}

model StudyGroupInvite {
  id          String   @id @default(uuid())
  fromUserId  String
  toUserId    String
  groupId     String?
  groupName   String?
  message     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  fromUser    User     @relation("inviteSent",     fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User     @relation("inviteReceived", fields: [toUserId],   references: [id], onDelete: Cascade)

  @@index([toUserId])
  @@map("study_group_invites")
}

model UserConnection {
  id          String   @id @default(uuid())
  userId      String
  connectedId String
  type        String   @default("classmate")
  createdAt   DateTime @default(now())
  user        User     @relation("connections", fields: [userId],      references: [id], onDelete: Cascade)
  connected   User     @relation("connectedBy", fields: [connectedId], references: [id], onDelete: Cascade)

  @@unique([userId, connectedId])
  @@map("user_connections")
}

// ─── Demandes d'accréditation (enseignant·e·s) ───────────────────
// Le premier contact — YEMA rencontre chaque prof avant de créer un
// compte TEACHER. Le statut évolue à la main dans /admin.
enum ApplicationStatus {
  RECEIVED    // en file
  CONTACTED   // à contacter
  MET         // entretien fait
  ACCREDITED  // accrédité, compte créé
  DECLINED    // décliné (courtoisement)
}

model TeacherApplication {
  id            String            @id @default(uuid())
  fullName      String
  email         String
  whatsapp      String?
  city          String
  languages     String            // langue(s) enseignée(s), texte libre
  experience    String            // diplôme / années d'expérience
  status        ApplicationStatus @default(RECEIVED)
  notes         String?           // notes internes admin
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("teacher_applications")
}

// ─── Profils enfants · formule Famille ────────────────────────────
// Un ChildProfile appartient à un compte parent (User.supabaseId via
// parentUserId). AUCUNE authentification propre. Les enfants sont
// sélectionnés depuis /famille.
//
// Multi-langues · un enfant peut apprendre plusieurs langues à la fois,
// certaines natales (échelle YEMA É1→É5) et d'autres étrangères
// (échelle douce M1→M4 · Premiers mots → On se raconte). Le CONTENU
// diffère (contes du pays vs comptines/jeux) mais le TON reste le
// même — chaleureux, ludique, terre.
//
// langues · jsonb ChildLangue[] · { langue, type, echelle, etoiles,
//   motsAppris } · une entrée par langue apprise.
// activeLangue · id de la langue en cours d'écoute · null si aucune
//   sélection n'a encore été faite.
model ChildProfile {
  id           String   @id @default(uuid())
  parentUserId String
  prenom       String
  avatarAnimal String
  age          Int
  langues      Json     @default("[]")
  activeLangue String?
  // P4.1 · rattachement explicite au foyer (opt-in, SetNull préserve enfant en cas de suppression foyer).
  householdId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent            User               @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  household         Household?         @relation("HouseholdChildren", fields: [householdId], references: [id], onDelete: SetNull)
  circleMemberships CircleMembership[]
  storageObjects    StorageObject[]    @relation("StorageObjectChildOwner")

  @@index([parentUserId])
  @@index([householdId])
  @@map("child_profiles")
}

// ─── P4.1 · Circle · unité privée Racines (Option A) ─────────────
// Un Circle représente le foyer en tant que groupe pédagogique privé
// pour une langue donnée. Un Household peut avoir plusieurs Circles s'il
// apprend plusieurs langues (kikongo + swahili → 2 Circles).
// Doctrine · docs/YEMA_P3_CIRCLE_DECISION.md + docs/YEMA_P4_ARCHITECTURE_AUDIT.md §5.
model Circle {
  id              String       @id @default(cuid())
  householdId     String
  language        LanguageCode
  status          CircleStatus @default(ACTIVE)
  createdByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  activeAt        DateTime     @default(now())
  archivedAt      DateTime?

  household   Household          @relation("HouseholdCircles", fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User               @relation("CircleCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  memberships CircleMembership[]
  invitations CircleInvitation[]

  // Note · l'unicité "un seul Circle non-archivé par (foyer, langue)" est
  // portée par un index partiel PostgreSQL créé dans la migration :
  //   CREATE UNIQUE INDEX ... ON circles (household_id, language) WHERE archived_at IS NULL;
  // Prisma ne sait pas exprimer un index partiel · on déclare uniquement un
  // index composite non-unique ici pour la lisibilité. Un Circle ARCHIVED
  // permet de recréer un nouveau Circle sur la même langue (Q8/Q9 validées).
  @@index([householdId, language])
  @@index([householdId, status])
  @@index([language, status])
  @@map("circles")
}

enum CircleStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

// ─── P4.1 · CircleMembership · appartenance typée ───────────────
// Un membership rattache soit un User adulte (OWNER, ADULT, COACH),
// soit un ChildProfile (CHILD). Contrainte XOR au niveau DB.
model CircleMembership {
  id              String                   @id @default(cuid())
  circleId        String
  role            CircleRole
  status          CircleMembershipStatus   @default(INVITED)
  userId          String?
  childProfileId  String?
  invitedByUserId String?
  joinedAt        DateTime?
  removedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  circle       Circle        @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user         User?         @relation("CircleUserMembership", fields: [userId], references: [id], onDelete: Cascade)
  childProfile ChildProfile? @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  invitedBy    User?         @relation("CircleInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([circleId, role, status])
  @@index([circleId, status])
  @@index([userId, status])
  @@index([childProfileId, status])
  @@map("circle_memberships")
}

enum CircleRole {
  OWNER
  ADULT
  CHILD
  COACH
}

enum CircleMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

// ─── P4.2 · CircleInvitation · workflow invitation adulte ───────
// Un OWNER invite un deuxième adulte par email (le hash de l'email est stocké
// pour éviter l'énumération). Le token brut n'est jamais stocké ni journalisé,
// seul son hash SHA-256. Expiration 72h. Usage unique.
model CircleInvitation {
  id                String            @id @default(cuid())
  circleId          String
  role              CircleRole
  status            InvitationStatus  @default(PENDING)
  invitedEmailHash  String
  invitedByUserId   String
  tokenHash         String
  expiresAt         DateTime
  acceptedAt        DateTime?
  acceptedByUserId  String?
  revokedAt         DateTime?
  revokedByUserId   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  circle       Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  invitedBy    User   @relation("InvitationInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy   User?  @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  revokedBy    User?  @relation("InvitationRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@unique([tokenHash])
  @@index([circleId, status])
  @@index([invitedEmailHash, status])
  @@index([expiresAt, status])
  @@map("circle_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// ─── P4.1 · AuditEvent · trace des actions sensibles ─────────────
// Ajouté dès P4.1 (avant P4.2 memberships) pour tracer immédiatement
// invitations, retraits, assignations coach, accès refusés, break-glass.
// Ne JAMAIS stocker corps de message, transcription audio, secret.
model AuditEvent {
  id           String       @id @default(cuid())
  actorUserId  String?
  actorRole    String?
  action       AuditAction
  targetType   String
  targetId     String
  scopeType    String?
  scopeId      String?
  metadata     Json?
  createdAt    DateTime     @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

enum AuditAction {
  CIRCLE_CREATED
  CIRCLE_ARCHIVED
  CIRCLE_SUSPENDED
  CIRCLE_MEMBERSHIP_INVITED
  CIRCLE_MEMBERSHIP_ACCEPTED
  CIRCLE_MEMBERSHIP_REVOKED
  CIRCLE_MEMBERSHIP_ROLE_CHANGED
  CIRCLE_COACH_ASSIGNED
  CIRCLE_COACH_UNASSIGNED
  HOUSEHOLD_MEMBERSHIP_INVITED
  HOUSEHOLD_MEMBERSHIP_ACCEPTED
  HOUSEHOLD_MEMBERSHIP_REVOKED
  CHILD_PROFILE_UPDATED
  CHILD_ACCESS_DENIED
  CROSS_TENANT_ACCESS_DENIED
  STORAGE_ACCESS_DENIED
  ADMIN_BREAK_GLASS_USED
  // P4.2 · workflow membership Circle
  ADULT_INVITED
  ADULT_INVITATION_REVOKED
  ADULT_INVITATION_ACCEPTED
  ADULT_LEFT_CIRCLE
  ADULT_REMOVED
  CHILD_ADDED
  CHILD_REMOVED
  COACH_ASSIGNMENT_REQUESTED
  COACH_ASSIGNED
  COACH_REMOVED
  MEMBERSHIP_ACCESS_DENIED
  // P4.3b · Teacher workspace refusals · voir permissions/teacher.ts + migration
  // 20260723000005_p4_3b_teacher_rls. Emis fire-and-forget sur les refus.
  TEACHER_ACCESS_DENIED
  TEACHER_CLASS_ACCESS_DENIED
  TEACHER_STUDENT_ACCESS_DENIED
  TEACHER_SCOPE_AMBIGUOUS
}

// ─── P4.1 · StorageObject · métadonnées uploads privés ───────────
// Aucun upload UI en P4.1. Le modèle est posé pour que P4.5/P4.6 puissent
// s'y appuyer sans migration supplémentaire. Aucun bucket public pour
// productions enfants (Q7 rétention 90 j Circle / 12 mois productions).
model StorageObject {
  id                  String                @id @default(cuid())
  bucket              String
  path                String
  ownerUserId         String?
  ownerChildProfileId String?
  circleId            String?
  classId             String?
  purpose             StorageObjectPurpose
  mimeType            String
  sizeBytes           Int
  durationSeconds     Int?
  retentionUntil      DateTime?
  createdAt           DateTime              @default(now())
  deletedAt           DateTime?

  owner        User?         @relation("StorageObjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerChild   ChildProfile? @relation("StorageObjectChildOwner", fields: [ownerChildProfileId], references: [id], onDelete: SetNull)

  @@unique([bucket, path])
  @@index([purpose, retentionUntil])
  @@index([ownerUserId, createdAt])
  @@index([circleId])
  @@index([classId])
  @@map("storage_objects")
}

enum StorageObjectPurpose {
  SUBMISSION_AUDIO
  FEEDBACK_AUDIO
  CIRCLE_MESSAGE_AUDIO
  CLASS_MESSAGE_AUDIO
  ATTACHMENT
}

// ─── Demandes de démo (centres) ──────────────────────────────────
// Sprint 7 · B2B. Formulaire court sur /landing.
model CenterApplication {
  id            String            @id @default(uuid())
  centerName    String
  city          String
  whatsapp      String?
  email         String
  status        ApplicationStatus @default(RECEIVED)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("center_applications")
}

model LanguageCenter {
  id           String    @id @default(uuid())
  name         String
  description  String?
  city         String
  country      String    @default("CM")
  phone        String?
  email        String?
  logoUrl      String?
  isVerified   Boolean   @default(false)
  plan         String    @default("starter")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  region       String?
  address      String?
  website      String?
  socialMedia  Json?
  openingHours Json?
  maxAdmins    Int       @default(5)
  rccm         String?
  centerType   String?
  foundedAt    DateTime?
  code         String?   @unique

  teachers   Teacher[]
  classrooms Classroom[]

